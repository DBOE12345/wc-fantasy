{
  "appId": "com.dubupfantasy.app",
  "appName": "DubUp Fantasy",
  "webDir": "dist",
  "server": {
    "url": "https://www.dubupfantasy.com",
    "cleartext": false
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0c1510"
  },
  "android": {
    "backgroundColor": "#0c1510"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0c1510",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0c1510"
    }
  }
}